# chia-blockchain farming fixes for pos2 / CHIP-48 (v2) plots
#
# These changes address presently unfinished upstream implementation of
# v2 farming in chia-blockchain. The code paths for v2 proof-of-space
# exist but are half-wired: services aren't started in the farmer
# group, the solver peer set is never populated, a message-handler
# signature doesn't match its decorator, ProofOfSpace.challenge is
# computed from the wrong input, and the harvester treats v2's bare
# absolute-path plot_identifier as though it carried a v1 quality-hex
# prefix. The dependency pin on chia_rs also excludes 0.42, which is
# where compute_plot_id_v2 landed.
#
# Target: Chia-Network/chia-blockchain @ commit 39f8bec88
#         ("2.7.0 Checkpoint Merge (#20725)")
#
# Apply:
#     git clone https://github.com/Chia-Network/chia-blockchain
#     cd chia-blockchain
#     git checkout 39f8bec88
#     git apply /path/to/testnet-farming.patch
#
# What this enables:
#   1. chia_solver in service_groups.py and the daemon name_map so
#      `chia start farmer` / `chia start solver` actually launch it.
#   2. start_farmer.py wires farmer.solver_peers into the farmer's
#      peer set so send_to_all(NodeType.SOLVER) reaches the solver.
#   3. FarmerAPI.solution_response handler's signature matches its
#      @metadata.request() decorator — current code raises TypeError
#      on every solver response and closes the connection in a loop.
#   4. Farmer computes ProofOfSpace.challenge as
#      calculate_pos_challenge(plot_id, challenge_hash, sp_hash)
#      instead of using the raw sub-slot challenge, so the local
#      validator stops rejecting solved proofs with "Calculated pos
#      challenge doesn't match the provided one".
#   5. Harvester request_signatures treats v2's bare-absolute-path
#      plot_identifier correctly (v1 prepends a 64-char quality hex,
#      v2 does not; current code unconditionally slices 64 chars off).
#   6. chia_rs dependency pin bumped from ">=0.41.1, <0.42" to
#      ">=0.42.0, <0.43" so compute_plot_id_v2 is available.
#
# Not included: the `chia plots create --v2` CPU-plotter CLI wiring.
# xchplot2 users plot with `xchplot2 plot` and farm the resulting
# .plot2 files via this patch, so that wiring is unnecessary here.

diff --git a/pyproject.toml b/pyproject.toml
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -53,7 +53,7 @@ boto3 = ">=1.35.43"  # AWS S3 for Data Layer S3 plugin
 chiabip158 = ">=1.5.2"  # bip158-style wallet filters
 chiapos = ">=2.0.10"  # proof of space
 chia-puzzles-py = ">=0.20.1"
-chia_rs = ">=0.41.1, <0.42"
+chia_rs = ">=0.42.0, <0.43"
 chiavdf = ">=1.1.10"  # timelord and vdf verification
 click = ">=8.1.7"  # For the CLI
 clvm = ">=0.9.14"
